# name: test/sql/duck_block_html.test
# description: Test html_to_duck_blocks and duck_blocks_to_html functions
# group: [sql]

require webbed

# Test basic heading extraction
query I
SELECT len(html_to_duck_blocks('<html><body><h1>Title</h1><p>Text</p></body></html>'));
----
2

# Test element kind is 'block'
query I
SELECT (html_to_duck_blocks('<h1>Hello</h1>'))[1].kind;
----
block

# Test heading element_type
query I
SELECT (html_to_duck_blocks('<h1>Hello</h1>'))[1].element_type;
----
heading

# Test heading level (now stored in attributes)
query I
SELECT (html_to_duck_blocks('<h1>Hello</h1>'))[1].attributes['heading_level'];
----
1

# Test h2 level (now stored in attributes)
query I
SELECT (html_to_duck_blocks('<h2>Hello</h2>'))[1].attributes['heading_level'];
----
2

# Test heading content
query I
SELECT (html_to_duck_blocks('<h1>Hello World</h1>'))[1].content;
----
Hello World

# Test paragraph extraction
query I
SELECT (html_to_duck_blocks('<p>Some text</p>'))[1].element_type;
----
paragraph

query I
SELECT (html_to_duck_blocks('<p>Some text</p>'))[1].content;
----
Some text

# Test code block extraction
query I
SELECT (html_to_duck_blocks('<pre><code class="language-python">print("hello")</code></pre>'))[1].element_type;
----
code

query I
SELECT (html_to_duck_blocks('<pre><code class="language-python">print("hello")</code></pre>'))[1].attributes['language'];
----
python

# Test unordered list extraction
query I
SELECT (html_to_duck_blocks('<ul><li>First</li><li>Second</li></ul>'))[1].element_type;
----
list

query I
SELECT (html_to_duck_blocks('<ul><li>First</li><li>Second</li></ul>'))[1].attributes['ordered'];
----
false

query I
SELECT (html_to_duck_blocks('<ul><li>First</li><li>Second</li></ul>'))[1].encoding;
----
json

# Test ordered list
query I
SELECT (html_to_duck_blocks('<ol><li>First</li><li>Second</li></ol>'))[1].attributes['ordered'];
----
true

# Test horizontal rule
query I
SELECT (html_to_duck_blocks('<hr>'))[1].element_type;
----
hr

# Test image extraction
query I
SELECT (html_to_duck_blocks('<img src="test.jpg" alt="Test image">'))[1].element_type;
----
image

query I
SELECT (html_to_duck_blocks('<img src="test.jpg" alt="Test image">'))[1].attributes['src'];
----
test.jpg

query I
SELECT (html_to_duck_blocks('<img src="test.jpg" alt="Test image">'))[1].attributes['alt'];
----
Test image

# Test element_order sequencing
query I
SELECT (html_to_duck_blocks('<h1>Title</h1><p>Para</p><h2>Subtitle</h2>'))[1].element_order;
----
0

query I
SELECT (html_to_duck_blocks('<h1>Title</h1><p>Para</p><h2>Subtitle</h2>'))[2].element_order;
----
1

query I
SELECT (html_to_duck_blocks('<h1>Title</h1><p>Para</p><h2>Subtitle</h2>'))[3].element_order;
----
2

# Test empty document
query I
SELECT len(html_to_duck_blocks('<html><body></body></html>'));
----
0

# Test blockquote with depth
query I
SELECT (html_to_duck_blocks('<blockquote>Quoted text</blockquote>'))[1].element_type;
----
blockquote

query I
SELECT (html_to_duck_blocks('<blockquote>Quoted text</blockquote>'))[1].level;
----
1

# Test table extraction
query I
SELECT (html_to_duck_blocks('<table><tr><th>Header</th></tr><tr><td>Data</td></tr></table>'))[1].element_type;
----
table

query I
SELECT (html_to_duck_blocks('<table><tr><th>Header</th></tr><tr><td>Data</td></tr></table>'))[1].encoding;
----
json

# Test heading with id attribute
query I
SELECT (html_to_duck_blocks('<h1 id="intro">Introduction</h1>'))[1].attributes['id'];
----
intro

# Test duck_blocks_to_html round-trip for headings
query I
SELECT duck_blocks_to_html(html_to_duck_blocks('<h1>Test Title</h1>'));
----
<h1>Test Title</h1>

# Test duck_blocks_to_html with paragraph
query I
SELECT duck_blocks_to_html(html_to_duck_blocks('<p>Some text content</p>'));
----
<p>Some text content</p>

# Test duck_blocks_to_html with code block
query I
SELECT duck_blocks_to_html(html_to_duck_blocks('<pre><code class="language-sql">SELECT 1</code></pre>'));
----
<pre><code class="language-sql">SELECT 1</code></pre>

# Test duck_blocks_to_html with hr
query I
SELECT duck_blocks_to_html(html_to_duck_blocks('<hr>'));
----
<hr>

# Test duck_blocks_to_html with image
query I
SELECT duck_blocks_to_html(html_to_duck_blocks('<img src="image.png" alt="An image">'));
----
<img src="image.png" alt="An image">

# Test VARCHAR input type
query I
SELECT len(html_to_duck_blocks('<h1>Title</h1>'::VARCHAR));
----
1

# =============================================================================
# doc_element API Tests (Unified Block/Inline Type)
# =============================================================================

# -----------------------------------------------------------------------------
# kind field tests - all block-level elements should have kind='block'
# -----------------------------------------------------------------------------

# Heading kind is 'block'
query I
SELECT (html_to_duck_blocks('<h1>Heading</h1>'))[1].kind;
----
block

# Paragraph kind is 'block'
query I
SELECT (html_to_duck_blocks('<p>Text</p>'))[1].kind;
----
block

# Code block kind is 'block'
query I
SELECT (html_to_duck_blocks('<pre><code>code</code></pre>'))[1].kind;
----
block

# Blockquote kind is 'block'
query I
SELECT (html_to_duck_blocks('<blockquote>Quote</blockquote>'))[1].kind;
----
block

# List kind is 'block'
query I
SELECT (html_to_duck_blocks('<ul><li>Item</li></ul>'))[1].kind;
----
block

# Table kind is 'block'
query I
SELECT (html_to_duck_blocks('<table><tr><td>Cell</td></tr></table>'))[1].kind;
----
block

# HR kind is 'block'
query I
SELECT (html_to_duck_blocks('<hr>'))[1].kind;
----
block

# Image kind is 'block'
query I
SELECT (html_to_duck_blocks('<img src="test.jpg">'))[1].kind;
----
block

# Metadata kind is 'block'
query I
SELECT (html_to_duck_blocks('<script type="application/vnd.frontmatter+yaml">title: Test</script>'))[1].kind;
----
block

# -----------------------------------------------------------------------------
# heading_level attribute tests - heading levels stored in attributes
# -----------------------------------------------------------------------------

# h1 has heading_level='1'
query I
SELECT (html_to_duck_blocks('<h1>H1</h1>'))[1].attributes['heading_level'];
----
1

# h2 has heading_level='2'
query I
SELECT (html_to_duck_blocks('<h2>H2</h2>'))[1].attributes['heading_level'];
----
2

# h3 has heading_level='3'
query I
SELECT (html_to_duck_blocks('<h3>H3</h3>'))[1].attributes['heading_level'];
----
3

# h4 has heading_level='4'
query I
SELECT (html_to_duck_blocks('<h4>H4</h4>'))[1].attributes['heading_level'];
----
4

# h5 has heading_level='5'
query I
SELECT (html_to_duck_blocks('<h5>H5</h5>'))[1].attributes['heading_level'];
----
5

# h6 has heading_level='6'
query I
SELECT (html_to_duck_blocks('<h6>H6</h6>'))[1].attributes['heading_level'];
----
6

# Heading can have both heading_level and id attributes
query I
SELECT (html_to_duck_blocks('<h2 id="section">Section</h2>'))[1].attributes['heading_level'];
----
2

query I
SELECT (html_to_duck_blocks('<h2 id="section">Section</h2>'))[1].attributes['id'];
----
section

# -----------------------------------------------------------------------------
# level field tests - NULL for headings, used for nesting depth
# -----------------------------------------------------------------------------

# Heading level field is NULL (heading level is in attributes)
query I
SELECT (html_to_duck_blocks('<h1>Heading</h1>'))[1].level IS NULL;
----
true

# Paragraph level field is NULL
query I
SELECT (html_to_duck_blocks('<p>Text</p>'))[1].level IS NULL;
----
true

# Code block level field is NULL
query I
SELECT (html_to_duck_blocks('<pre><code>code</code></pre>'))[1].level IS NULL;
----
true

# Blockquote level field contains nesting depth
query I
SELECT (html_to_duck_blocks('<blockquote>Quote</blockquote>'))[1].level;
----
1

# Nested blockquote has higher level (inner blockquote is second element)
query I
SELECT (html_to_duck_blocks('<blockquote><blockquote>Nested</blockquote></blockquote>'))[2].level;
----
2

# List level field is NULL
query I
SELECT (html_to_duck_blocks('<ul><li>Item</li></ul>'))[1].level IS NULL;
----
true

# Table level field is NULL
query I
SELECT (html_to_duck_blocks('<table><tr><td>Cell</td></tr></table>'))[1].level IS NULL;
----
true

# HR level field is NULL
query I
SELECT (html_to_duck_blocks('<hr>'))[1].level IS NULL;
----
true

# Image level field is NULL
query I
SELECT (html_to_duck_blocks('<img src="test.jpg">'))[1].level IS NULL;
----
true

# -----------------------------------------------------------------------------
# Heading round-trip tests - verify heading levels are preserved
# -----------------------------------------------------------------------------

# h1 round-trip
query I
SELECT duck_blocks_to_html(html_to_duck_blocks('<h1>Title</h1>'));
----
<h1>Title</h1>

# h2 round-trip
query I
SELECT duck_blocks_to_html(html_to_duck_blocks('<h2>Subtitle</h2>'));
----
<h2>Subtitle</h2>

# h3 round-trip
query I
SELECT duck_blocks_to_html(html_to_duck_blocks('<h3>Section</h3>'));
----
<h3>Section</h3>

# h4 round-trip
query I
SELECT duck_blocks_to_html(html_to_duck_blocks('<h4>Subsection</h4>'));
----
<h4>Subsection</h4>

# h5 round-trip
query I
SELECT duck_blocks_to_html(html_to_duck_blocks('<h5>Minor</h5>'));
----
<h5>Minor</h5>

# h6 round-trip
query I
SELECT duck_blocks_to_html(html_to_duck_blocks('<h6>Smallest</h6>'));
----
<h6>Smallest</h6>

# Heading with id attribute round-trip
query I
SELECT duck_blocks_to_html(html_to_duck_blocks('<h2 id="intro">Introduction</h2>'));
----
<h2 id="intro">Introduction</h2>

# Multiple headings with different levels
query I
SELECT duck_blocks_to_html(html_to_duck_blocks('<h1>Title</h1><h2>Section</h2><h3>Subsection</h3>'));
----
<h1>Title</h1><h2>Section</h2><h3>Subsection</h3>

