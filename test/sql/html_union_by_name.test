# name: test/sql/html_union_by_name.test
# description: Test union_by_name parameter for read_html (feature parity with read_xml)
# group: [sql]

require webbed

# Test 1: sample_files:=1 samples only the first file, so the schema is file 1's columns
# (the pre-sampling default). The multi-file default and union_by_name both see field-c too.
query TTTTTT
SELECT * FROM (DESCRIBE SELECT * FROM read_html(['test/html/union_file1.html', 'test/html/union_file2.html'], record_element:='data-item', sample_files:=1)) ORDER BY column_name;
----
field-a	VARCHAR	YES	NULL	NULL	NULL
field-b	INTEGER	YES	NULL	NULL	NULL

# Test 2: With union_by_name - should get all columns (union)
query TTTTTT
SELECT * FROM (DESCRIBE SELECT * FROM read_html(['test/html/union_file1.html', 'test/html/union_file2.html'], record_element:='data-item', union_by_name:=true)) ORDER BY column_name;
----
field-a	VARCHAR	YES	NULL	NULL	NULL
field-b	INTEGER	YES	NULL	NULL	NULL
field-c	VARCHAR	YES	NULL	NULL	NULL

# Test 3: Verify data from both files is present
query I
SELECT count(*) FROM read_html(['test/html/union_file1.html', 'test/html/union_file2.html'], record_element:='data-item', union_by_name:=true);
----
4

# Test 4: Verify NULL values for missing columns
query ITT
SELECT "field-b", "field-a", "field-c"
FROM read_html(['test/html/union_file1.html', 'test/html/union_file2.html'], record_element:='data-item', union_by_name:=true)
ORDER BY COALESCE("field-a", ''), COALESCE("field-b", 0);
----
300	NULL	extra1
100	value1	NULL
200	value2	NULL
NULL	value3	extra2

# Test 5: Verify column types are correctly inferred across files
query TTT
SELECT typeof("field-a"), typeof("field-b"), typeof("field-c")
FROM read_html(['test/html/union_file1.html', 'test/html/union_file2.html'], record_element:='data-item', union_by_name:=true)
LIMIT 1;
----
VARCHAR	INTEGER	VARCHAR

# Test 6: Test with all_varchar and union_by_name together
query TTTTTT
SELECT * FROM (DESCRIBE SELECT * FROM read_html(['test/html/union_file1.html', 'test/html/union_file2.html'], record_element:='data-item', union_by_name:=true, all_varchar:=true)) ORDER BY column_name;
----
field-a	VARCHAR	YES	NULL	NULL	NULL
field-b	VARCHAR	YES	NULL	NULL	NULL
field-c	VARCHAR	YES	NULL	NULL	NULL

# Test 7: STRUCT widening parity with read_xml (union_by_name unions disjoint inner fields)
query T
SELECT typeof(item) FROM read_html(['test/html/struct_widen/a1.html', 'test/html/struct_widen/a2.html'],
    record_element := 'doc', union_by_name := true) LIMIT 1;
----
STRUCT("field-a" INTEGER, "field-b" INTEGER)

# Both files must contribute rows, with disjoint fields populated.
query II
SELECT item."field-a", item."field-b"
FROM read_html(['test/html/struct_widen/a1.html', 'test/html/struct_widen/a2.html'],
    record_element := 'doc', union_by_name := true)
ORDER BY item."field-a" NULLS LAST;
----
1	NULL
NULL	2
