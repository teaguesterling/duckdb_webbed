# name: test/sql/github_issue_53_html_extract_text.test
# description: Test html_extract_text UTF-8 support and multiple element matching
# group: [sql]
#
# GitHub Issue #53: How to extract html tag content with UTF-8 support?
# https://github.com/teaguesterling/duckdb_webbed/issues/53
#
# ISSUE 1: UTF-8 Encoding (FIXED)
# Previously, html_extract_text with XPath would garble UTF-8 characters
# (e.g., "chère" became "chÃ¨re"). This was fixed by specifying UTF-8 encoding
# explicitly in htmlReadMemory().
#
# ISSUE 2: Only First Match Returned (DOCUMENTED BEHAVIOR)
# html_extract_text with XPath like '//p' only returns the first matching element,
# not all matching elements. This is by design.

require webbed

# ============================================================================
# PART 1: UTF-8 Encoding Tests (verifying the fix works)
# ============================================================================

# Test 1.1: French accented characters (returns list)
query I
SELECT html_extract_text('<html><body><p>chère</p></body></html>', '//p');
----
[chère]

# Test 1.2: Single UTF-8 character preserved correctly (returns list)
query I
SELECT html_extract_text('<html><body><p>è</p></body></html>', '//p');
----
[è]

# Test 1.3: German umlauts (returns list)
query I
SELECT html_extract_text('<html><body><span>Größe und Öffnung</span></body></html>', '//span');
----
[Größe und Öffnung]

# Test 1.4: Spanish characters (returns list)
query I
SELECT html_extract_text('<html><body><div>Señor España ¿Cómo está?</div></body></html>', '//div');
----
[Señor España ¿Cómo está?]

# Test 1.5: Nordic characters (returns list)
query I
SELECT html_extract_text('<html><body><p>Ærlig ønsker jeg å være</p></body></html>', '//p');
----
[Ærlig ønsker jeg å være]

# Test 1.6: Mixed accented characters (returns list)
query I
SELECT html_extract_text('<html><body><p>Café résumé naïve</p></body></html>', '//p');
----
[Café résumé naïve]

# Test 1.7: Currency symbols (UTF-8) (returns list)
query I
SELECT html_extract_text('<html><body><p>Price: €50 &amp; £30</p></body></html>', '//p');
----
['Price: €50 & £30']

# Test 1.8: Chinese characters (returns list)
query I
SELECT html_extract_text('<html><body><p>你好世界</p></body></html>', '//p');
----
[你好世界]

# Test 1.9: Japanese characters (returns list)
query I
SELECT html_extract_text('<html><body><p>こんにちは</p></body></html>', '//p');
----
[こんにちは]

# Test 1.10: Emoji (extended UTF-8) (returns list)
query I
SELECT html_extract_text('<html><body><p>Hello 🌍 World 🎉</p></body></html>', '//p');
----
[Hello 🌍 World 🎉]

# Test 1.11: File-based UTF-8 test (use len for list)
query I
SELECT len(html_extract_text(html, '//p')) > 0
FROM read_html_objects('test/html/github_issue_53_utf8.html');
----
true

# Test 1.12: ASCII content still works (returns list)
query I
SELECT html_extract_text('<html><body><p>hello world</p></body></html>', '//p');
----
[hello world]

# ============================================================================
# PART 2: Multiple Element Matching Tests (NOW RETURNS ALL MATCHES!)
# ============================================================================

# Test 2.1: All <p> elements now returned as list
query I
SELECT html_extract_text('<p>First paragraph</p><p>Second paragraph</p>', '//p');
----
[First paragraph, Second paragraph]

# Test 2.2: Multiple list items - all returned as list
query I
SELECT html_extract_text(
    '<html><body><ul><li>One</li><li>Two</li><li>Three</li></ul></body></html>',
    '//li'
);
----
[One, Two, Three]

# Test 2.3: File-based test - multiple paragraphs (all returned as list)
query I
SELECT html_extract_text(html, '//p')
FROM read_html_objects('test/html/github_issue_53_multi_match.html');
----
[Paragraph one, Paragraph two, Paragraph three]

# Test 2.4: File-based test - multiple list items (all returned as list)
query I
SELECT html_extract_text(html, '//li')
FROM read_html_objects('test/html/github_issue_53_multi_match.html');
----
[First item, Second item, Third item]

# ============================================================================
# PART 3: Edge Cases
# ============================================================================

# Test 3.1: Empty list when no match
query I
SELECT html_extract_text('<html><body><div>No paragraphs here</div></body></html>', '//p');
----
[]

# Test 3.2: Nested elements - text extraction concatenates (returns list)
query I
SELECT html_extract_text(
    '<html><body><div><p>Outer <span>inner</span> text</p></div></body></html>',
    '//p'
);
----
[Outer inner text]

# Test 3.3: Deep nesting (returns list)
query I
SELECT html_extract_text(
    '<html><body><div><div><div><p>Deep</p></div></div></div></body></html>',
    '//p'
);
----
[Deep]

# Test 3.4: Attribute selector (returns list)
query I
SELECT html_extract_text(
    '<html><body><p class="a">First</p><p class="b">Second</p></body></html>',
    '//p[@class="b"]'
);
----
[Second]

# Test 3.5: HTML entities are decoded correctly (returns list)
query I
SELECT html_extract_text(
    '<html><body><p>Hello &amp; goodbye &lt;tag&gt;</p></body></html>',
    '//p'
);
----
[Hello & goodbye <tag>]

# ============================================================================
# PART 4: html_unescape also handles UTF-8 correctly
# ============================================================================

# Test 4.1: html_unescape with UTF-8
query I
SELECT html_unescape('<p>Café résumé</p>');
----
Café résumé

# Test 4.2: html_unescape with file content
query I
SELECT length(html_unescape(html::VARCHAR)) > 0
FROM read_html_objects('test/html/github_issue_53_utf8.html');
----
true
