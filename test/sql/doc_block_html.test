# name: test/sql/doc_block_html.test
# description: Test html_to_doc_blocks and doc_blocks_to_html functions
# group: [sql]

require webbed

# Test basic heading extraction
query I
SELECT len(html_to_doc_blocks('<html><body><h1>Title</h1><p>Text</p></body></html>'));
----
2

# Test heading block_type
query I
SELECT (html_to_doc_blocks('<h1>Hello</h1>'))[1].block_type;
----
heading

# Test heading level
query I
SELECT (html_to_doc_blocks('<h1>Hello</h1>'))[1].level;
----
1

# Test h2 level
query I
SELECT (html_to_doc_blocks('<h2>Hello</h2>'))[1].level;
----
2

# Test heading content
query I
SELECT (html_to_doc_blocks('<h1>Hello World</h1>'))[1].content;
----
Hello World

# Test paragraph extraction
query I
SELECT (html_to_doc_blocks('<p>Some text</p>'))[1].block_type;
----
paragraph

query I
SELECT (html_to_doc_blocks('<p>Some text</p>'))[1].content;
----
Some text

# Test code block extraction
query I
SELECT (html_to_doc_blocks('<pre><code class="language-python">print("hello")</code></pre>'))[1].block_type;
----
code

query I
SELECT (html_to_doc_blocks('<pre><code class="language-python">print("hello")</code></pre>'))[1].attributes['language'];
----
python

# Test unordered list extraction
query I
SELECT (html_to_doc_blocks('<ul><li>First</li><li>Second</li></ul>'))[1].block_type;
----
list

query I
SELECT (html_to_doc_blocks('<ul><li>First</li><li>Second</li></ul>'))[1].attributes['ordered'];
----
false

query I
SELECT (html_to_doc_blocks('<ul><li>First</li><li>Second</li></ul>'))[1].encoding;
----
json

# Test ordered list
query I
SELECT (html_to_doc_blocks('<ol><li>First</li><li>Second</li></ol>'))[1].attributes['ordered'];
----
true

# Test horizontal rule
query I
SELECT (html_to_doc_blocks('<hr>'))[1].block_type;
----
hr

# Test image extraction
query I
SELECT (html_to_doc_blocks('<img src="test.jpg" alt="Test image">'))[1].block_type;
----
image

query I
SELECT (html_to_doc_blocks('<img src="test.jpg" alt="Test image">'))[1].attributes['src'];
----
test.jpg

query I
SELECT (html_to_doc_blocks('<img src="test.jpg" alt="Test image">'))[1].attributes['alt'];
----
Test image

# Test block_order sequencing
query I
SELECT (html_to_doc_blocks('<h1>Title</h1><p>Para</p><h2>Subtitle</h2>'))[1].block_order;
----
0

query I
SELECT (html_to_doc_blocks('<h1>Title</h1><p>Para</p><h2>Subtitle</h2>'))[2].block_order;
----
1

query I
SELECT (html_to_doc_blocks('<h1>Title</h1><p>Para</p><h2>Subtitle</h2>'))[3].block_order;
----
2

# Test empty document
query I
SELECT len(html_to_doc_blocks('<html><body></body></html>'));
----
0

# Test blockquote with depth
query I
SELECT (html_to_doc_blocks('<blockquote>Quoted text</blockquote>'))[1].block_type;
----
blockquote

query I
SELECT (html_to_doc_blocks('<blockquote>Quoted text</blockquote>'))[1].level;
----
1

# Test table extraction
query I
SELECT (html_to_doc_blocks('<table><tr><th>Header</th></tr><tr><td>Data</td></tr></table>'))[1].block_type;
----
table

query I
SELECT (html_to_doc_blocks('<table><tr><th>Header</th></tr><tr><td>Data</td></tr></table>'))[1].encoding;
----
json

# Test heading with id attribute
query I
SELECT (html_to_doc_blocks('<h1 id="intro">Introduction</h1>'))[1].attributes['id'];
----
intro

# Test doc_blocks_to_html round-trip for headings
query I
SELECT doc_blocks_to_html(html_to_doc_blocks('<h1>Test Title</h1>'));
----
<h1>Test Title</h1>

# Test doc_blocks_to_html with paragraph
query I
SELECT doc_blocks_to_html(html_to_doc_blocks('<p>Some text content</p>'));
----
<p>Some text content</p>

# Test doc_blocks_to_html with code block
query I
SELECT doc_blocks_to_html(html_to_doc_blocks('<pre><code class="language-sql">SELECT 1</code></pre>'));
----
<pre><code class="language-sql">SELECT 1</code></pre>

# Test doc_blocks_to_html with hr
query I
SELECT doc_blocks_to_html(html_to_doc_blocks('<hr>'));
----
<hr>

# Test doc_blocks_to_html with image
query I
SELECT doc_blocks_to_html(html_to_doc_blocks('<img src="image.png" alt="An image">'));
----
<img src="image.png" alt="An image">

# Test VARCHAR input type
query I
SELECT len(html_to_doc_blocks('<h1>Title</h1>'::VARCHAR));
----
1

# =============================================================================
# Frontmatter/Metadata Block Tests (Issue #56)
# =============================================================================

# Test frontmatter script extraction
query I
SELECT (html_to_doc_blocks('<script type="application/vnd.frontmatter+yaml">title: Test</script>'))[1].block_type;
----
metadata

# Test frontmatter encoding is yaml
query I
SELECT (html_to_doc_blocks('<script type="application/vnd.frontmatter+yaml">title: Test</script>'))[1].encoding;
----
yaml

# Test frontmatter content extraction
query I
SELECT (html_to_doc_blocks('<script type="application/vnd.frontmatter+yaml">title: Test</script>'))[1].content;
----
title: Test

# Test frontmatter block_order is 0
query I
SELECT (html_to_doc_blocks('<script type="application/vnd.frontmatter+yaml">title: Test</script><h1>Title</h1>'))[1].block_order;
----
0

# Test content block_order follows frontmatter
query I
SELECT (html_to_doc_blocks('<script type="application/vnd.frontmatter+yaml">title: Test</script><h1>Title</h1>'))[2].block_order;
----
1

# Test multi-line YAML frontmatter preservation (verify content contains expected lines)
query I
SELECT length((html_to_doc_blocks('<script type="application/vnd.frontmatter+yaml">title: Test
author: John
tags:
  - doc
  - test</script>'))[1].content) > 30;
----
true

# Test frontmatter contains expected YAML keys
query I
SELECT contains((html_to_doc_blocks('<script type="application/vnd.frontmatter+yaml">title: Test
author: John</script>'))[1].content, 'author: John');
----
true

# Test frontmatter round-trip (verify structure is preserved)
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<script type="application/vnd.frontmatter+yaml">title: Test</script><h1>Title</h1>')), 'application/vnd.frontmatter+yaml');
----
true

# Test frontmatter round-trip contains heading
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<script type="application/vnd.frontmatter+yaml">title: Test</script><h1>Title</h1>')), '<h1>Title</h1>');
----
true

# Test frontmatter round-trip contains YAML content
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<script type="application/vnd.frontmatter+yaml">title: Test</script><h1>Title</h1>')), 'title: Test');
----
true

# Test only regular scripts are ignored (not frontmatter type)
query I
SELECT len(html_to_doc_blocks('<script>console.log("hi")</script><h1>Title</h1>'));
----
1

# Test document with only frontmatter
query I
SELECT len(html_to_doc_blocks('<script type="application/vnd.frontmatter+yaml">title: Test</script>'));
----
1

# =============================================================================
# Table Round-Trip Tests (Issue #57)
# =============================================================================

# Test table round-trip produces table tag
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>Name</th><th>Age</th></tr><tr><td>Alice</td><td>30</td></tr></table>')), '<table>');
----
true

# Test table round-trip contains thead
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><thead><tr><th>Name</th><th>Age</th></tr></thead><tbody><tr><td>Alice</td><td>30</td></tr></tbody></table>')), '<thead>');
----
true

# Test table round-trip contains header cell
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>Name</th><th>Age</th></tr><tr><td>Alice</td><td>30</td></tr></table>')), '<th>Name</th>');
----
true

# Test table round-trip contains tbody
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><thead><tr><th>Name</th><th>Age</th></tr></thead><tbody><tr><td>Alice</td><td>30</td></tr></tbody></table>')), '<tbody>');
----
true

# Test table round-trip contains data cell
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>Name</th><th>Age</th></tr><tr><td>Alice</td><td>30</td></tr></table>')), '<td>Alice</td>');
----
true

# Test table round-trip with multiple rows
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>Col1</th></tr><tr><td>Row1</td></tr><tr><td>Row2</td></tr></table>')), '<td>Row2</td>');
----
true

# Test table HTML escaping in cells (special chars should be escaped)
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>Test</th></tr><tr><td>&lt;script&gt;</td></tr></table>')), '&lt;');
----
true

# Test empty table renders correctly
query I
SELECT doc_blocks_to_html(html_to_doc_blocks('<table></table>'));
----
<table><tbody></tbody></table>

# Test table with only headers (no data rows)
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><thead><tr><th>Header1</th><th>Header2</th></tr></thead></table>')), '<th>Header1</th>');
----
true

# Test table with only data rows (no explicit headers)
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tbody><tr><td>Data1</td><td>Data2</td></tr></tbody></table>')), '<td>Data1</td>');
----
true

# Test table with special characters in cells (ampersand)
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>Col</th></tr><tr><td>A &amp; B</td></tr></table>')), '&amp;');
----
true

# Test table with special characters in cells (quotes)
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>Col</th></tr><tr><td>Say &quot;Hello&quot;</td></tr></table>')), 'Hello');
----
true

# Test table with many columns
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>A</th><th>B</th><th>C</th><th>D</th><th>E</th></tr><tr><td>1</td><td>2</td><td>3</td><td>4</td><td>5</td></tr></table>')), '<th>E</th>');
----
true

# Test table with many rows
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>X</th></tr><tr><td>R1</td></tr><tr><td>R2</td></tr><tr><td>R3</td></tr><tr><td>R4</td></tr><tr><td>R5</td></tr></table>')), '<td>R5</td>');
----
true

# Test table cell content is preserved exactly
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>Name</th></tr><tr><td>John Doe</td></tr></table>')), 'John Doe');
----
true

# Test table with numeric content
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>Price</th></tr><tr><td>$19.99</td></tr></table>')), '$19.99');
----
true

# Test table structure is complete (closing tags)
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>H</th></tr><tr><td>D</td></tr></table>')), '</table>');
----
true

# Test table tbody closing tag present
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>H</th></tr><tr><td>D</td></tr></table>')), '</tbody>');
----
true

# Test table thead closing tag present
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><thead><tr><th>H</th></tr></thead><tbody><tr><td>D</td></tr></tbody></table>')), '</thead>');
----
true

# Test table with whitespace in cells
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>Col</th></tr><tr><td>  spaced  </td></tr></table>')), 'spaced');
----
true

# Test table row structure (tr tags)
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>H</th></tr><tr><td>D</td></tr></table>')), '</tr>');
----
true

# Test multiple tables in document
query I
SELECT len(html_to_doc_blocks('<table><tr><th>T1</th></tr></table><p>text</p><table><tr><th>T2</th></tr></table>'));
----
3

# Test table block_type is correct
query I
SELECT (html_to_doc_blocks('<table><tr><th>H</th></tr></table>'))[1].block_type;
----
table

# Test table encoding is json
query I
SELECT (html_to_doc_blocks('<table><tr><th>H</th></tr></table>'))[1].encoding;
----
json

# Test table JSON content contains headers key
query I
SELECT contains((html_to_doc_blocks('<table><tr><th>MyHeader</th></tr></table>'))[1].content, 'headers');
----
true

# Test table JSON content contains rows key
query I
SELECT contains((html_to_doc_blocks('<table><tr><th>H</th></tr><tr><td>D</td></tr></table>'))[1].content, 'rows');
----
true

# Test table with empty cells
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>H</th></tr><tr><td></td></tr></table>')), '<td></td>');
----
true

# Test table preserves cell order
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>First</th><th>Second</th><th>Third</th></tr></table>')), '<th>First</th><th>Second</th><th>Third</th>');
----
true

# Test table with Unicode content
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>名前</th></tr><tr><td>田中</td></tr></table>')), '田中');
----
true

# Test table with emoji
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>Status</th></tr><tr><td>✓ Done</td></tr></table>')), '✓');
----
true

# Test table with greater than/less than
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>Expr</th></tr><tr><td>x &gt; 5</td></tr></table>')), '&gt;');
----
true

# Test single cell table
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><td>Single</td></tr></table>')), 'Single');
----
true

# Test table row order is preserved (first row first)
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>H</th></tr><tr><td>First</td></tr><tr><td>Second</td></tr></table>')), '<td>First</td></tr><tr><td>Second</td>');
----
true

# Test table with colons (common in data)
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>Time</th></tr><tr><td>12:30:00</td></tr></table>')), '12:30:00');
----
true

# Test table with commas (common in numbers)
query I
SELECT contains(doc_blocks_to_html(html_to_doc_blocks('<table><tr><th>Amount</th></tr><tr><td>1,234,567</td></tr></table>')), '1,234,567');
----
true

# Test table header text content extraction
query I
SELECT (html_to_doc_blocks('<table><tr><th>Simple Header</th></tr></table>'))[1].content;
----
{"headers":["Simple Header"],"rows":[]}

# Test table with single row of data
query I
SELECT contains((html_to_doc_blocks('<table><tr><th>H</th></tr><tr><td>D</td></tr></table>'))[1].content, '"rows":[["D"]]');
----
true
