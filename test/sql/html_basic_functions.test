# name: test/sql/html_basic_functions.test
# description: Test basic HTML functions that should work with current XML infrastructure
# group: [sql]

require webbed

# Test that html_extract_text works on HTML type (returns list)
# Note: Use html_extract_text for HTML content; xml_extract_text requires valid XML (single root)
query I
SELECT html_extract_text('<h1>Title</h1><p>Content</p>'::HTML, '//h1');
----
[Title]

# Test xml_extract_elements on HTML type (cast to VARCHAR, returns list)
query I
SELECT xml_extract_elements('<ul><li>Item 1</li><li>Item 2</li></ul>'::HTML::VARCHAR, '//li');
----
[<li>Item 1</li>, <li>Item 2</li>]

# Test xml_extract_attributes on HTML type (cast to VARCHAR)
query IIIII
SELECT
    (unnest(xml_extract_attributes('<a href="test.html" title="Test">Link</a>'::HTML::VARCHAR, '//a'))).element_name,
    (unnest(xml_extract_attributes('<a href="test.html" title="Test">Link</a>'::HTML::VARCHAR, '//a'))).attribute_name,
    (unnest(xml_extract_attributes('<a href="test.html" title="Test">Link</a>'::HTML::VARCHAR, '//a'))).attribute_value,
    (unnest(xml_extract_attributes('<a href="test.html" title="Test">Link</a>'::HTML::VARCHAR, '//a'))).element_path,
    (unnest(xml_extract_attributes('<a href="test.html" title="Test">Link</a>'::HTML::VARCHAR, '//a'))).line_number;
----
a	href	test.html	/a	1
a	title	Test	/a	1

# Test HTML-specific XPath on HTML type (cast to VARCHAR, returns list)
query I
SELECT xml_extract_text('<html><head><title>Page Title</title></head><body><h1>Header</h1></body></html>'::HTML::VARCHAR, '//title');
----
[Page Title]

# Test complex HTML with XML functions (cast to VARCHAR, returns list)
query I
SELECT xml_extract_text('<div class="content"><span>Text content</span></div>'::HTML::VARCHAR, '//span');
----
[Text content]