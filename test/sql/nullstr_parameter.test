# name: test/sql/nullstr_parameter.test
# description: Test nullstr parameter for custom NULL value representation (#40)
# group: [sql]

require webbed

# Test 1: Default behavior - without nullstr, N/A and - are regular strings
# score column should be VARCHAR because "N/A" is not numeric
query TTTTTT
DESCRIBE SELECT * FROM read_xml('test/xml/nullstr_test.xml');
----
score	VARCHAR	YES	NULL	NULL	NULL
grade	VARCHAR	YES	NULL	NULL	NULL
name	VARCHAR	YES	NULL	NULL	NULL

# Test 2: Single nullstr value - N/A becomes NULL, enabling numeric inference for score
query TTTTTT
DESCRIBE SELECT * FROM read_xml('test/xml/nullstr_test.xml', nullstr='N/A');
----
score	INTEGER	YES	NULL	NULL	NULL
grade	VARCHAR	YES	NULL	NULL	NULL
name	VARCHAR	YES	NULL	NULL	NULL

# Test 3: Verify data with single nullstr
query III
SELECT * FROM read_xml('test/xml/nullstr_test.xml', nullstr='N/A');
----
95	A	Alice
NULL	-	Bob
87	NULL	Charlie

# Test 4: Nullstr with all_varchar=true - matched values still become NULL
query III
SELECT * FROM read_xml('test/xml/nullstr_test.xml', nullstr='N/A', all_varchar=true);
----
95	A	Alice
NULL	-	Bob
87	NULL	Charlie

# Test 5: Nullstr doesn't affect non-matching values
query III
SELECT * FROM read_xml('test/xml/nullstr_test.xml', nullstr='MISSING');
----
95	A	Alice
N/A	-	Bob
87	NULL	Charlie

# Test 6: Case sensitivity - nullstr should be case-sensitive
query III
SELECT * FROM read_xml('test/xml/nullstr_test.xml', nullstr='n/a');
----
95	A	Alice
N/A	-	Bob
87	NULL	Charlie

# Test 7: Default behavior unchanged when nullstr not specified
query III
SELECT * FROM read_xml('test/xml/nullstr_test.xml');
----
95	A	Alice
N/A	-	Bob
87	NULL	Charlie

# Test 8: Works with parse_xml
query II
SELECT * FROM parse_xml('<?xml version="1.0"?><records><record><name>Alice</name><value>N/A</value></record><record><name>Bob</name><value>42</value></record></records>', nullstr='N/A');
----
NULL	Alice
42	Bob
